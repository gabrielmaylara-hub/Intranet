@{
    var logoPath = ViewData["logoPath"] as string ?? "";
    var nombreSitio = ViewData["nombreSitio"] as string ?? "Intranet FGET";
    var config = ViewData["siteConfig"] as Dictionary<string, string> ?? new();
    var subtitulo = config.GetValueOrDefault("header_subtitulo", "Fiscalía General del Estado de Tabasco");
    var enlaces = ViewData["headerLinks"] as IEnumerable<SitioEnlace> ?? Enumerable.Empty<SitioEnlace>();
    var rutaActual = Context.Request.Path.Value ?? "";

    bool EsExterno(string url) =>
        Uri.TryCreate(url, UriKind.Absolute, out var uri) &&
        (uri.Scheme == Uri.UriSchemeHttp || uri.Scheme == Uri.UriSchemeHttps);

    bool EsActivo(string ruta)
    {
        if (EsExterno(ruta))
            return false;

        var rutaBase = ruta.Split('?', '#')[0];
        return rutaBase == "/"
            ? rutaActual == "/"
            : rutaActual.StartsWith(rutaBase, StringComparison.OrdinalIgnoreCase);
    }
}
<header class="site-header">
    <div class="header-inner">
        <a href="/" class="header-marca" aria-label="Ir al inicio">
            @if (!string.IsNullOrWhiteSpace(logoPath))
            {
                <img src="/storage/@logoPath" alt="FGET" class="header-logo" />
            }
            else
            {
                <img src="~/img/logo-fget.jpeg" alt="FGET" class="header-logo" asp-append-version="true" />
            }
            <div class="header-nombre">
                <span class="header-nombre-principal">@nombreSitio</span>
                <span class="header-nombre-sub">@subtitulo</span>
            </div>
        </a>

        <nav class="header-nav" aria-label="Navegación principal">
            <button class="nav-toggle" id="navToggle" aria-label="Abrir menú" aria-expanded="false">
                <span></span><span></span><span></span>
            </button>
            <ul class="nav-lista" id="navLista" role="list">
                @foreach (var enlace in enlaces)
                {
                    var externo = EsExterno(enlace.Url);
                    <li>
                        <a href="@enlace.Url"
                           class="nav-enlace @(EsActivo(enlace.Url) ? "nav-enlace--activo" : "")"
                           target="@(externo ? "_blank" : null)"
                           rel="@(externo ? "noopener noreferrer" : null)">
                            @enlace.Texto
                        </a>
                    </li>
                }
            </ul>
        </nav>
    </div>
</header>
