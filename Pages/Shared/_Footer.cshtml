@{
    var config = ViewData["siteConfig"] as Dictionary<string, string> ?? new();
    var recursos = ViewData["footerRecursosLinks"] as IEnumerable<SitioEnlace> ?? Enumerable.Empty<SitioEnlace>();
    var sistemas = ViewData["footerSistemasLinks"] as IEnumerable<SitioEnlace> ?? Enumerable.Empty<SitioEnlace>();
    var textoFoot = config.GetValueOrDefault("footer_texto", "Fiscalía General del Estado de Tabasco");
    var subTexto = config.GetValueOrDefault("footer_subtexto", "Dirección General de Informática y Estadística");
    var recursosTitulo = config.GetValueOrDefault("footer_recursos_titulo", "RECURSOS");
    var sistemasTitulo = config.GetValueOrDefault("footer_sistemas_titulo", "SISTEMAS");
    var contactoTitulo = config.GetValueOrDefault("footer_contacto_titulo", "CONTACTO");
    var email = config.GetValueOrDefault("footer_contacto_email", "");
    var telefono = config.GetValueOrDefault("footer_contacto_tel", "");
    var direccion = config.GetValueOrDefault("footer_direccion", "Villahermosa, Tabasco, México");
    var copyright = config.GetValueOrDefault(
        "footer_copyright",
        "© 2026 Fiscalía General del Estado de Tabasco. Todos los derechos reservados.");

    bool EsExterno(string url) =>
        Uri.TryCreate(url, UriKind.Absolute, out var uri) &&
        (uri.Scheme == Uri.UriSchemeHttp || uri.Scheme == Uri.UriSchemeHttps);
}
<footer class="site-footer">
    <div class="footer-inner">
        <div class="footer-col footer-col--identidad">
            <p class="footer-nombre">@textoFoot</p>
            <p class="footer-sub">@subTexto</p>
        </div>

        <div class="footer-col">
            <h3 class="footer-titulo">@recursosTitulo</h3>
            <ul class="footer-lista" role="list">
                @foreach (var enlace in recursos)
                {
                    var externo = EsExterno(enlace.Url);
                    <li>
                        <a href="@enlace.Url"
                           class="footer-enlace"
                           target="@(externo ? "_blank" : null)"
                           rel="@(externo ? "noopener noreferrer" : null)">
                            @enlace.Texto
                        </a>
                    </li>
                }
            </ul>
        </div>

        <div class="footer-col">
            <h3 class="footer-titulo">@sistemasTitulo</h3>
            <ul class="footer-lista" role="list">
                @foreach (var enlace in sistemas)
                {
                    var externo = EsExterno(enlace.Url);
                    <li>
                        <a href="@enlace.Url"
                           class="footer-enlace"
                           target="@(externo ? "_blank" : null)"
                           rel="@(externo ? "noopener noreferrer" : null)">
                            @enlace.Texto
                        </a>
                    </li>
                }
            </ul>
        </div>

        <div class="footer-col">
            <h3 class="footer-titulo">@contactoTitulo</h3>
            <ul class="footer-lista footer-lista--contacto" role="list">
                @if (!string.IsNullOrWhiteSpace(email))
                {
                    <li>
                        <a href="mailto:@email" class="footer-enlace">@email</a>
                    </li>
                }
                @if (!string.IsNullOrWhiteSpace(telefono))
                {
                    <li><span class="footer-texto">@telefono</span></li>
                }
                @if (!string.IsNullOrWhiteSpace(direccion))
                {
                    <li><span class="footer-texto">@direccion</span></li>
                }
            </ul>
        </div>
    </div>

    <div class="footer-copy">
        <p>@copyright</p>
    </div>
</footer>
