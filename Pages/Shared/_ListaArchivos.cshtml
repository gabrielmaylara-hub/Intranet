@model IEnumerable<Intranet.Models.ArchivoSeccion>

@if (Model != null && Model.Any())
{
    <ul class="archivos-lista" role="list">
        @foreach (var archivo in Model)
        {
            <li class="archivo-item">
                <div class="archivo-icono" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                        <polyline points="14 2 14 8 20 8"/>
                        <line x1="16" y1="13" x2="8" y2="13"/>
                        <line x1="16" y1="17" x2="8" y2="17"/>
                        <polyline points="10 9 9 9 8 9"/>
                    </svg>
                </div>
                <div class="archivo-info">
                    <span class="archivo-nombre">@archivo.Nombre</span>
                    @if (!string.IsNullOrWhiteSpace(archivo.Descripcion))
                    {
                        <span class="archivo-descripcion">@archivo.Descripcion</span>
                    }
                </div>
                <a href="/storage/@archivo.ArchivoPath"
                   class="archivo-descargar"
                   download
                   aria-label="Descargar @archivo.Nombre">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                        <polyline points="7 10 12 15 17 10"/>
                        <line x1="12" y1="15" x2="12" y2="3"/>
                    </svg>
                    Descargar
                </a>
            </li>
        }
    </ul>
}
else
{
    <div class="seccion-vacia">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
            <polyline points="14 2 14 8 20 8"/>
        </svg>
        <p>No hay archivos disponibles en este momento.</p>
        <p class="seccion-vacia-sub">El administrador puede subir archivos desde el panel.</p>
    </div>
}
