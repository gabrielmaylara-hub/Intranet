@page
@model Intranet.Pages.Admin.Avisos.IndexModel
@{
    Layout = "_LayoutAdmin";
    ViewData["TituloAdmin"] = "Avisos y Comunicados";
}

@if (!string.IsNullOrEmpty(Model.Mensaje))
{
    <div class="alerta @(Model.EsError ? "alerta-error" : "alerta-exito")" role="alert">
        @Model.Mensaje
    </div>
}

@if (Model.EsAdminGeneralActual)
{
    <div class="admin-panel">
        <form method="get" class="form-dos-columnas">
            <div class="campo-grupo">
                <label class="campo-label" for="AreaFiltro">Filtrar por área</label>
                <select class="campo-input" id="AreaFiltro" name="AreaFiltro" onchange="this.form.submit()">
                    <option value="">Todas las áreas</option>
                    @foreach (var area in Model.Areas)
                    {
                        <option value="@area.Id" selected="@(Model.AreaFiltro == area.Id ? "selected" : null)">
                            @area.Nombre
                        </option>
                    }
                </select>
            </div>
            <div class="campo-grupo">
                <label class="campo-label">&nbsp;</label>
                <a class="btn btn-neutro" href="/Admin/Avisos">Limpiar filtro</a>
            </div>
        </form>
    </div>
}
else if (!string.IsNullOrWhiteSpace(Model.AreaActualNombre))
{
    <div class="alerta alerta-exito" role="status">
        Publicando como: @Model.AreaActualNombre
    </div>
}
else
{
    <div class="alerta alerta-error" role="alert">
        Tu usuario no tiene un área de publicación activa asignada. Solicita apoyo a un admin_general.
    </div>
}

<div class="admin-panel">
    <div class="panel-cabecera">
        <h2 class="admin-panel-titulo">Avisos publicados</h2>
        @if (Model.PuedeGestionarAvisos)
        {
            <button type="button" class="btn btn-primario btn-sm" id="btnNuevo">+ Nuevo aviso</button>
        }
    </div>

    <div class="tabla-wrap">
        <table class="admin-tabla">
            <thead>
                <tr>
                    <th>Título</th>
                    <th>Área</th>
                    <th>Fecha</th>
                    <th>Adjunto</th>
                    <th>Estado</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var aviso in Model.Avisos)
                {
                    <tr>
                        <td>@aviso.Titulo</td>
                        <td>
                            @if (string.IsNullOrWhiteSpace(aviso.AreaPublicacionNombre))
                            {
                                <span class="texto-gris">Sin área</span>
                            }
                            else
                            {
                                @aviso.AreaPublicacionNombre
                            }
                        </td>
                        <td>@aviso.FechaPublicacion.ToString("dd/MM/yyyy")</td>
                        <td>
                            @if (aviso.TienePdf)
                            {
                                <span class="badge badge-activo">PDF</span>
                            }
                            else
                            {
                                <span class="texto-gris">Sin PDF</span>
                            }
                        </td>
                        <td>
                            <span class="badge @(aviso.Activo ? "badge-activo" : "badge-inactivo")">
                                @(aviso.Activo ? "Activo" : "Inactivo")
                            </span>
                        </td>
                        <td class="td-acciones">
                            @if (Model.PuedeGestionarAvisos)
                            {
                                <button type="button"
                                        class="btn btn-sm btn-secundario btn-editar"
                                        data-id="@aviso.Id"
                                        data-titulo="@aviso.Titulo"
                                        data-contenido="@aviso.Contenido"
                                        data-fecha="@aviso.FechaPublicacion.ToString("yyyy-MM-dd")"
                                        data-area-publicacion-id="@aviso.AreaPublicacionId"
                                        data-tiene-pdf="@aviso.TienePdf.ToString().ToLower()"
                                        data-pdf-nombre="@aviso.PdfNombreOriginal"
                                        data-activo="@aviso.Activo.ToString().ToLower()">
                                    Editar
                                </button>

                                <form method="post" asp-page-handler="Toggle" class="form-inline">
                                    <input type="hidden" name="id" value="@aviso.Id" />
                                    <input type="hidden" name="AreaFiltro" value="@Model.AreaFiltro" />
                                    @Html.AntiForgeryToken()
                                    <button type="submit"
                                            class="btn btn-sm @(aviso.Activo ? "btn-advertencia" : "btn-exito")">
                                        @(aviso.Activo ? "Desactivar" : "Activar")
                                    </button>
                                </form>

                                <form method="post" asp-page-handler="Eliminar" class="form-inline"
                                      onsubmit="return confirm('¿Eliminar el aviso «@aviso.Titulo»?')">
                                    <input type="hidden" name="id" value="@aviso.Id" />
                                    <input type="hidden" name="AreaFiltro" value="@Model.AreaFiltro" />
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-peligro">Eliminar</button>
                                </form>
                            }
                        </td>
                    </tr>
                }
                @if (!Model.Avisos.Any())
                {
                    <tr>
                        <td colspan="6" class="texto-gris">No hay avisos para mostrar.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@if (Model.PuedeGestionarAvisos)
{
    <div class="admin-panel" id="panelFormulario" hidden>
        <h2 class="admin-panel-titulo" id="formTitulo">Nuevo aviso</h2>

        <form method="post" asp-page-handler="Guardar" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <input type="hidden" name="Id" id="formId" value="0" />
            <input type="hidden" name="AreaFiltro" value="@Model.AreaFiltro" />

            <div class="campo-grupo">
                <label class="campo-label">Título <span class="campo-requerido">*</span></label>
                <input type="text" name="Titulo" id="formTituloInput" class="campo-input" maxlength="200" required />
            </div>

            <div class="campo-grupo">
                <label class="campo-label">Contenido <span class="campo-requerido">*</span></label>
                <textarea name="Contenido" id="formContenido" class="campo-textarea" rows="4" maxlength="4000" required></textarea>
            </div>

            @if (Model.EsAdminGeneralActual)
            {
                <div class="campo-grupo">
                    <label class="campo-label" for="formAreaPublicacionId">Área de publicación</label>
                    <select name="AreaPublicacionId" id="formAreaPublicacionId" class="campo-input">
                        <option value="">Sin área</option>
                        @foreach (var area in Model.Areas)
                        {
                            <option value="@area.Id">@area.Nombre</option>
                        }
                    </select>
                    <span class="campo-ayuda">Los avisos sin área quedan administrables solo por admin_general.</span>
                </div>
            }
            else
            {
                <div class="campo-grupo">
                    <label class="campo-label">Área de publicación</label>
                    <input type="text" class="campo-input" value="@Model.AreaActualNombre" disabled />
                    <span class="campo-ayuda">El aviso se guardará automáticamente en tu área.</span>
                </div>
            }

            <div class="campo-grupo">
                <label class="campo-label" for="formPdfAdjunto">PDF adjunto</label>
                <input type="file"
                       name="PdfAdjunto"
                       id="formPdfAdjunto"
                       class="campo-input"
                       accept=".pdf,application/pdf" />
                <span class="campo-ayuda">Opcional. Solo se permite PDF.</span>
                <div class="campo-ayuda" id="formPdfActual" hidden>
                    PDF actual: <span id="formPdfActualNombre"></span>
                    <label class="campo-check campo-check-inline" id="formQuitarPdfWrapper">
                        <input type="checkbox" name="QuitarPdf" id="formQuitarPdf" value="true" />
                        Quitar PDF actual
                    </label>
                    <input type="hidden" name="QuitarPdf" value="false" />
                </div>
            </div>

            <div class="form-dos-columnas">
                <div class="campo-grupo">
                    <label class="campo-label">Fecha de publicación</label>
                    <input type="date" name="FechaPublicacion" id="formFecha"
                           class="campo-input"
                           value="@Model.FechaPublicacion" />
                </div>
                <div class="campo-grupo campo-grupo--checks">
                    <label class="campo-check">
                        <input type="checkbox" name="Activo" id="formActivo" value="true" checked />
                        Publicar aviso
                    </label>
                    <input type="hidden" name="Activo" value="false" />
                </div>
            </div>

            <div class="form-acciones">
                <button type="submit" class="btn btn-primario">Guardar</button>
                <button type="button" class="btn btn-neutro" id="btnCancelar">Cancelar</button>
            </div>
        </form>
    </div>
}
