@page
@model Intranet.Pages.Admin.AreasPublicacion.IndexModel
@{
    Layout = "_LayoutAdmin";
    ViewData["TituloAdmin"] = "Áreas de publicación";
    var editando = Model.Id > 0;
}

@if (!string.IsNullOrWhiteSpace(Model.Mensaje))
{
    <div class="alerta @(Model.EsError ? "alerta-error" : "alerta-exito")" role="alert">
        @Model.Mensaje
    </div>
}

@Html.AntiForgeryToken()

<div class="alerta" id="mensajeReordenAreas" role="alert" hidden></div>

<div class="admin-panel">
    <div class="panel-cabecera">
        <div>
            <h2 class="admin-panel-titulo">Áreas de publicación</h2>
            <p class="campo-ayuda">
                Estas áreas controlan qué contenido podrá administrar cada usuario de área.
                No dependen del Directorio telefónico.
            </p>
        </div>
        <a class="btn btn-primario btn-sm" href="/Admin/AreasPublicacion">Nueva área</a>
    </div>

    <form method="post" asp-page-handler="Guardar">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />

        <div class="campo-grupo">
            <label class="campo-label" asp-for="Nombre">Nombre <span class="campo-requerido">*</span></label>
            <input class="campo-input" asp-for="Nombre" maxlength="180" required />
        </div>

        <div class="campo-grupo">
            <label class="campo-label" asp-for="Descripcion">Descripción</label>
            <input class="campo-input" asp-for="Descripcion" maxlength="300" />
        </div>

        <div class="campo-grupo campo-grupo--checks">
            <label class="campo-check">
                <input type="checkbox" asp-for="Activa" />
                Activa
            </label>
        </div>

        <div class="form-acciones">
            <button type="submit" class="btn btn-primario">
                @(editando ? "Guardar cambios" : "Crear área")
            </button>
            @if (editando)
            {
                <a class="btn btn-neutro" href="/Admin/AreasPublicacion">Cancelar edición</a>
            }
        </div>
    </form>
</div>

@section Scripts {
    <script src="~/lib/sortablejs/Sortable.min.js"></script>
    <script>
        const tablaAreasPublicacion = document.getElementById('tablaAreasPublicacion');
        const tokenAreasPublicacion = document.querySelector('input[name=__RequestVerificationToken]')?.value;
        const mensajeReordenAreas = document.getElementById('mensajeReordenAreas');

        function mostrarMensajeReordenAreas(texto, esError) {
            if (!mensajeReordenAreas) {
                return;
            }

            mensajeReordenAreas.textContent = texto;
            mensajeReordenAreas.hidden = false;
            mensajeReordenAreas.className = `alerta ${esError ? 'alerta-error' : 'alerta-exito'}`;
        }

        if (tablaAreasPublicacion && tokenAreasPublicacion && window.Sortable) {
            let ordenAnteriorAreas = [];

            const sortableAreasPublicacion = Sortable.create(tablaAreasPublicacion, {
                animation: 150,
                handle: '.drag-handle',
                onStart: function () {
                    ordenAnteriorAreas = [...tablaAreasPublicacion.querySelectorAll('tr[data-id]')]
                        .map(tr => tr.dataset.id);
                },
                onEnd: async function () {
                    const items = [...tablaAreasPublicacion.querySelectorAll('tr[data-id]')]
                        .map((tr, idx) => ({ id: parseInt(tr.dataset.id), orden: idx + 1 }));

                    try {
                        const response = await fetch('/Admin/AreasPublicacion?handler=Reordenar', {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/json',
                                'X-XSRF-TOKEN': tokenAreasPublicacion
                            },
                            body: JSON.stringify(items)
                        });

                        let data = null;
                        try {
                            data = await response.json();
                        } catch {
                            data = null;
                        }

                        if (!response.ok || !data || data.ok !== true) {
                            throw new Error(data?.message || 'No se pudo guardar el nuevo orden.');
                        }

                        mostrarMensajeReordenAreas(data.message || 'Orden actualizado correctamente.', false);
                    } catch (error) {
                        if (ordenAnteriorAreas.length > 0) {
                            sortableAreasPublicacion.sort(ordenAnteriorAreas);
                        }

                        mostrarMensajeReordenAreas(
                            error.message || 'No se pudo guardar el nuevo orden.',
                            true);

                        window.setTimeout(() => window.location.reload(), 1200);
                    }
                }
            });
        }
    </script>
}

<div class="admin-panel">
    <h2 class="admin-panel-titulo">Listado</h2>
    <p class="campo-ayuda">Arrastra las filas para reordenar. El orden se guarda automáticamente.</p>

    <div class="tabla-wrap">
        <table class="admin-tabla">
            <thead>
                <tr>
                    <th class="col-drag"></th>
                    <th>Nombre</th>
                    <th>Slug</th>
                    <th>Estado</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody id="tablaAreasPublicacion">
                @foreach (var area in Model.Areas)
                {
                    <tr data-id="@area.Id">
                        <td class="col-drag">
                            <span class="drag-handle" title="Arrastrar para reordenar">::</span>
                        </td>
                        <td>
                            <strong>@area.Nombre</strong>
                            @if (!string.IsNullOrWhiteSpace(area.Descripcion))
                            {
                                <span class="texto-gris bloque">@area.Descripcion</span>
                            }
                        </td>
                        <td><code>@area.Slug</code></td>
                        <td>
                            <span class="badge @(area.Activa ? "badge-activo" : "badge-inactivo")">
                                @(area.Activa ? "Activa" : "Inactiva")
                            </span>
                        </td>
                        <td class="td-acciones">
                            <a class="btn btn-sm btn-secundario"
                               href="/Admin/AreasPublicacion?editarId=@area.Id">
                                Editar
                            </a>

                            @if (area.Activa)
                            {
                                <form method="post" asp-page-handler="Desactivar" class="form-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@area.Id" />
                                    <button type="submit" class="btn btn-sm btn-advertencia">Desactivar</button>
                                </form>
                            }
                            else
                            {
                                <form method="post" asp-page-handler="Activar" class="form-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@area.Id" />
                                    <button type="submit" class="btn btn-sm btn-exito">Activar</button>
                                </form>
                            }

                            <form method="post"
                                  asp-page-handler="Eliminar"
                                  class="form-inline"
                                  onsubmit="return confirm('Eliminar el área @area.Nombre?')">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@area.Id" />
                                <button type="submit" class="btn btn-sm btn-peligro">Eliminar</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
