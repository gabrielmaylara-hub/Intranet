@page
@model TutorialesModel
@{
    ViewData["Title"] = "Tutoriales";
}

<section class="seccion-pagina">
    <div class="seccion-inner">
        <div class="pagina-encabezado">
            <h1 class="pagina-titulo">Tutoriales Institucionales</h1>
            <p class="pagina-descripcion">
                Videos de capacitación y guías de uso de los sistemas institucionales
                de la Fiscalía General del Estado de Tabasco.
            </p>
        </div>

        @if (Model.Tutoriales.Any())
        {
            <div class="tutoriales-grid">
                @foreach (var tut in Model.Tutoriales)
                {
                    var posterPath = !string.IsNullOrWhiteSpace(tut.MiniaturaPath)
                        ? $"/storage/{tut.MiniaturaPath}"
                        : null;

                    <article class="tutorial-card" id="tutorial-@tut.Id">
                        @if (!string.IsNullOrWhiteSpace(tut.ArchivoPath))
                        {
                            <!-- Reproductor de video HTML5 nativo -->
                            <div class="tutorial-video-wrap">
                                <video class="tutorial-video"
                                       controls
                                       preload="metadata"
                                       poster="@posterPath">
                                    <source src="/storage/@tut.ArchivoPath" type="video/mp4" />
                                    Tu navegador no soporta reproducción de video.
                                </video>
                            </div>
                        }
                        else
                        {
                            <div class="tutorial-sin-video">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                    <polygon points="5 3 19 12 5 21 5 3"/>
                                </svg>
                                <span>Video próximamente</span>
                            </div>
                        }

                        <div class="tutorial-card-info">
                            <h2 class="tutorial-card-titulo">@tut.Titulo</h2>
                            @if (!string.IsNullOrWhiteSpace(tut.Descripcion))
                            {
                                <p class="tutorial-card-desc">@tut.Descripcion</p>
                            }
                            <time class="tutorial-card-fecha"
                                  datetime="@tut.FechaCreacion.ToString("yyyy-MM-dd")">
                                @tut.FechaCreacion.ToString("dd 'de' MMMM 'de' yyyy",
                                    new System.Globalization.CultureInfo("es-MX"))
                            </time>
                        </div>
                    </article>
                }
            </div>
        }
        else
        {
            <div class="seccion-vacia">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                    <polygon points="5 3 19 12 5 21 5 3"/>
                </svg>
                <p>No hay tutoriales publicados en este momento.</p>
            </div>
        }
    </div>
</section>
