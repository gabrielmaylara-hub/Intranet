@page
@model Intranet.Pages.DirectorioModel
@{
    ViewData["Title"] = "Directorio";
}

<section class="seccion-pagina directorio-pagina" aria-labelledby="tituloDirectorio">
    <div class="seccion-inner directorio-contenedor">
        <header class="pagina-encabezado directorio-encabezado">
            <span class="directorio-kicker">Consulta institucional</span>
            <h1 class="pagina-titulo" id="tituloDirectorio">Directorio</h1>
            <p class="pagina-descripcion">
                Consulta de &aacute;reas y extensiones institucionales.
            </p>
            <p class="directorio-nota">
                Informaci&oacute;n capturada desde el m&oacute;dulo administrativo del Directorio.
            </p>
        </header>

        <form method="get"
              class="directorio-buscador"
              data-directorio-buscador
              aria-label="Buscar en Directorio">
            <div class="directorio-buscador-principal">
                <label for="directorio-q">B&uacute;squeda general</label>
                <input type="search"
                       id="directorio-q"
                       name="q"
                       data-directorio-auto
                       value="@Model.Q"
                       placeholder="Buscar por &aacute;rea, unidad, extensi&oacute;n, titular, ubicaci&oacute;n o correo" />
            </div>

            <div class="directorio-buscador-grid">
                <div>
                    <label for="directorio-area">&Aacute;rea</label>
                    <select id="directorio-area"
                            name="area"
                            data-directorio-auto>
                        <option value="">Todas las &aacute;reas</option>
                        @foreach (var area in Model.AreasBusqueda)
                        {
                            if (string.Equals(Model.Area, area.Nombre, StringComparison.OrdinalIgnoreCase))
                            {
                                <option value="@area.Nombre" selected>@area.Nombre</option>
                            }
                            else
                            {
                                <option value="@area.Nombre">@area.Nombre</option>
                            }
                        }
                    </select>
                </div>
                <div>
                    <label for="directorio-extension">Extensi&oacute;n</label>
                    <input type="search"
                           id="directorio-extension"
                           name="extension"
                           data-directorio-auto
                           value="@Model.Extension"
                           placeholder="Ej. 4017" />
                </div>
            </div>

            <div class="directorio-buscador-acciones">
                <button type="submit" class="btn btn-primario">Buscar</button>
                @if (Model.TieneBusqueda)
                {
                    <a class="directorio-buscador-limpiar" asp-page="/Directorio">Limpiar b&uacute;squeda</a>
                }
            </div>
        </form>

        @if (Model.Grupos.Any())
        {
            <div class="directorio-lista" aria-label="Listado de areas y extensiones">
                @foreach (var grupo in Model.Grupos)
                {
                    var idGrupo = $"directorio-{grupo.Area.Id}";
                    var tieneTitular = !string.IsNullOrWhiteSpace(grupo.Area.Titular);
                    var tieneUbicacion = !string.IsNullOrWhiteSpace(grupo.Area.Ubicacion);
                    var tieneCorreo = !string.IsNullOrWhiteSpace(grupo.Area.Correo);

                    <section class="directorio-grupo" aria-labelledby="@idGrupo">
                        <h2 class="directorio-area" id="@idGrupo">@grupo.Area.Nombre</h2>
                        @if (tieneTitular || tieneUbicacion || tieneCorreo)
                        {
                            <dl class="directorio-meta">
                                @if (tieneTitular)
                                {
                                    <div>
                                        <dt>Titular:</dt>
                                        <dd>@grupo.Area.Titular</dd>
                                    </div>
                                }
                                @if (tieneUbicacion)
                                {
                                    <div>
                                        <dt>Ubicaci&oacute;n:</dt>
                                        <dd>@grupo.Area.Ubicacion</dd>
                                    </div>
                                }
                                @if (tieneCorreo)
                                {
                                    <div>
                                        <dt>Correo:</dt>
                                        <dd><a href="mailto:@grupo.Area.Correo">@grupo.Area.Correo</a></dd>
                                    </div>
                                }
                            </dl>
                        }
                        <div class="directorio-filas">
                            @foreach (var entrada in grupo.Entradas)
                            {
                                <div class="directorio-fila">
                                    <span class="directorio-nombre">@entrada.Nombre</span>
                                    <span class="directorio-extension">@entrada.Extension</span>
                                </div>
                            }
                        </div>
                    </section>
                }
            </div>
        }
        else
        {
            <p class="directorio-vacio">
                @(Model.TieneBusqueda
                    ? "No se encontraron extensiones con los criterios seleccionados."
                    : "No hay extensiones publicadas por el momento.")
            </p>
        }
    </div>
</section>
