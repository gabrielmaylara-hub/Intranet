@page
@model ManualesModel
@{
    ViewData["Title"] = Model.Titulo;
}

<section class="seccion-pagina">
    <div class="seccion-inner">
        <div class="pagina-encabezado">
            <h1 class="pagina-titulo">@Model.Titulo</h1>
            <p class="pagina-descripcion">@Model.Descripcion</p>
        </div>

        @await Html.PartialAsync("_ListaArchivos", Model.Archivos)
    </div>
</section>
